---
import type { RichTextNode } from '@/lib/sections/document';
import { isLeaf, markTagsFor } from '@/lib/sections/document';
import RichTextMarks from './RichTextMarks.astro';

interface Props {
  node: RichTextNode;
}
const { node } = Astro.props;

const leaf = isLeaf(node) ? node : null;
const el = isLeaf(node) ? null : node;

const GENERIC_TAGS: Record<string, string> = {
  paragraph: 'p',
  blockquote: 'blockquote',
  'unordered-list': 'ul',
  'ordered-list': 'ol',
  'list-item': 'li',
};

let kind: 'leaf' | 'heading' | 'divider' | 'code' | 'link' | 'fragment' | 'generic' = 'fragment';
if (leaf) {
  kind = 'leaf';
} else if (el) {
  if (el.type === 'heading') kind = 'heading';
  else if (el.type === 'divider') kind = 'divider';
  else if (el.type === 'code') kind = 'code';
  else if (el.type === 'link') kind = 'link';
  else if (GENERIC_TAGS[el.type]) kind = 'generic';
  else kind = 'fragment';
}

// Runtime value is the real tag; the cast only satisfies the type checker.
const HeadingTag = (el && el.type === 'heading'
  ? `h${Math.min(Math.max(el.level ?? 2, 1), 6)}`
  : 'h2') as 'h2';
const GenericTag = (el ? (GENERIC_TAGS[el.type] ?? 'div') : 'div') as 'div';
const alignStyle = el?.textAlign ? `text-align:${el.textAlign}` : undefined;
const href = el?.href ?? '#';
---
{kind === 'leaf' && leaf && (
  <RichTextMarks tags={markTagsFor(leaf)}>{leaf.text}</RichTextMarks>
)}
{kind === 'heading' && el && (
  <HeadingTag style={alignStyle}>{el.children.map((c) => <Astro.self node={c} />)}</HeadingTag>
)}
{kind === 'generic' && el && (
  <GenericTag style={alignStyle}>{el.children.map((c) => <Astro.self node={c} />)}</GenericTag>
)}
{kind === 'link' && el && (
  <a href={href}>{el.children.map((c) => <Astro.self node={c} />)}</a>
)}
{kind === 'code' && el && (
  <pre><code>{el.children.map((c) => <Astro.self node={c} />)}</code></pre>
)}
{kind === 'divider' && <hr />}
{kind === 'fragment' && el && (
  <Fragment>{el.children.map((c) => <Astro.self node={c} />)}</Fragment>
)}
