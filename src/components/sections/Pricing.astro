---
import type { PricingProps } from '@/lib/sections/pricing';
import JsonLd from '@/components/JsonLd.astro';

const { title, plans, headingLevel } = Astro.props as PricingProps;
const Heading = `h${headingLevel}` as 'h1' | 'h2';

const offers = plans
  .filter((p) => p.priceAmount !== undefined && p.currency)
  .map((p) => ({
    '@type': 'Offer',
    name: p.name,
    price: p.priceAmount,
    priceCurrency: p.currency,
    ...(p.interval && p.interval !== 'once'
      ? {
          priceSpecification: {
            '@type': 'UnitPriceSpecification',
            billingDuration: p.interval === 'month' ? 'P1M' : 'P1Y',
          },
        }
      : {}),
  }));
const jsonLd =
  offers.length > 0
    ? {
        '@context': 'https://schema.org',
        '@type': 'Product',
        name: title ?? 'Plans',
        offers,
      }
    : null;
---
<section class="pricing">
  <div class="container">
    {title && <Heading class="pricing__title">{title}</Heading>}
    <ul class="pricing__list">
      {plans.map((plan) => (
        <li class={`pricing__plan ${plan.highlighted ? 'pricing__plan--highlighted' : ''}`}>
          <h3 class="pricing__plan-name">{plan.name}</h3>
          <p class="pricing__plan-price">
            <span class="pricing__price">{plan.price}</span>
            {plan.interval && plan.interval !== 'once' && (
              <span class="pricing__interval">/ {plan.interval === 'month' ? 'mo' : 'yr'}</span>
            )}
          </p>
          {plan.description && <p class="pricing__description">{plan.description}</p>}
          <ul class="pricing__features">
            {plan.features.map((f) => <li>✓ {f}</li>)}
          </ul>
          <a class={`pricing__cta ${plan.highlighted ? 'pricing__cta--primary' : ''}`} href={plan.ctaUrl}>{plan.ctaText}</a>
        </li>
      ))}
    </ul>
  </div>
  {jsonLd && <JsonLd data={jsonLd} />}
</section>

<style>
  .pricing { padding-block: var(--space-section-y); }
  .pricing__title { font-size: var(--font-size-2xl); margin: 0 0 var(--space-8); text-align: center; }
  .pricing__list { list-style: none; padding: 0; margin: 0; display: grid; gap: var(--space-6); grid-template-columns: repeat(auto-fit, minmax(16rem, 1fr)); max-width: 60rem; margin-inline: auto; }
  .pricing__plan { background: var(--color-bg); border: 1px solid var(--color-border); padding: var(--space-6); border-radius: var(--radius-lg); display: flex; flex-direction: column; }
  .pricing__plan--highlighted { border-color: var(--color-accent); border-width: 2px; }
  .pricing__plan-name { font-size: var(--font-size-lg); margin: 0 0 var(--space-3); }
  .pricing__plan-price { margin: 0 0 var(--space-4); }
  .pricing__price { font-size: var(--font-size-2xl); font-weight: 700; }
  .pricing__interval { color: var(--color-muted); }
  .pricing__description { color: var(--color-muted); margin: 0 0 var(--space-4); }
  .pricing__features { list-style: none; padding: 0; margin: 0 0 var(--space-6); flex: 1; }
  .pricing__features li { padding-block: var(--space-1); }
  .pricing__cta { display: block; text-align: center; padding: var(--space-3) var(--space-4); border: 1px solid var(--color-fg); color: var(--color-fg); text-decoration: none; border-radius: var(--radius-md); }
  .pricing__cta--primary { background: var(--color-accent); color: var(--color-accent-fg); border-color: var(--color-accent); }
  .pricing__cta:hover { opacity: 0.85; }
</style>
