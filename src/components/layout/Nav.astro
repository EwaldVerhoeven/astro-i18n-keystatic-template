---
import { useTranslations, type Lang } from '@/i18n/utils';
import LanguagePicker from './LanguagePicker.astro';
import { getCollection } from 'astro:content';

interface Props {
  lang: Lang;
  translationKey?: string;
}

const { lang } = Astro.props;
const t = useTranslations(lang);
const globals = await getCollection('globals');
const siteName = globals[0]?.data.siteName ?? 'Site';
---
<header class="site-nav">
  <div class="container site-nav__inner">
    <a class="site-nav__brand" href={`/${lang}/`}>{siteName}</a>
    <nav aria-label="Primary">
      <ul class="site-nav__list">
        <li><a href={`/${lang}/`}>{t('nav.home')}</a></li>
        <li><a href={`/${lang}/blog/`}>{t('nav.blog')}</a></li>
      </ul>
    </nav>
    <LanguagePicker currentLang={lang} />
  </div>
</header>

<style>
  .site-nav { border-bottom: 1px solid var(--color-border); padding-block: var(--space-4); }
  .site-nav__inner { display: flex; align-items: center; gap: var(--space-6); }
  .site-nav__brand { font-weight: 700; text-decoration: none; color: var(--color-fg); }
  .site-nav__list { display: flex; gap: var(--space-4); list-style: none; padding: 0; margin: 0; flex: 1; }
  .site-nav__list a { color: var(--color-fg); text-decoration: none; }
  .site-nav__list a:hover { color: var(--color-accent); }
</style>
